# nexaOSweb Brain environment. Copy to .env and fill in. Never commit .env.

# Database. Defaults to a local SQLite file when unset.
DATABASE_URL=

# Web session signing secret and cookie security
NEXA_SESSION_SECRET=
NEXA_PUBLIC_HTTPS=

# Static bearer token for the desktop client
NEXA_DESKTOP_BEARER=

# On disk roots
NEXA_PROJECTS_ROOT=
NEXA_UPLOADS_ROOT=

# Comma separated allowed CORS origins
CORS_ORIGINS=

# Provider keys, read only by the Brain
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
TAVILY_API_KEY=
