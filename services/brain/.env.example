# nexaOSweb Brain environment. Copy to .env and fill in. Never commit .env.
#
# IMPORTANT: storage paths must be ABSOLUTE. A relative path resolves against the working
# directory, so launching the Brain from a different folder points it at a different database and
# an empty secret store, silently losing logins, providers, and data. Use full absolute paths, for
# example /workspaces/nexaOSweb/services/brain/data/nexaos.db.

# Database. Absolute sqlite path uses four slashes: sqlite:////abs/path/nexaos.db
DATABASE_URL=

# Web session signing secret and cookie security
NEXA_SESSION_SECRET=
NEXA_PUBLIC_HTTPS=

# Static bearer token for the desktop client
NEXA_DESKTOP_BEARER=

# On disk roots. All must be ABSOLUTE paths (blank here on purpose).
NEXA_SECRETS_ROOT=
NEXA_RUNTIME_ROOT=
NEXA_PROJECTS_ROOT=
NEXA_UPLOADS_ROOT=

# Comma separated allowed CORS origins
CORS_ORIGINS=

# Durable account seed, read on boot. Leave blank here; set real values in the local .env only.
# NEXA_SEED_ON_BOOT enables the seed; NEXA_SEED_FORCE_PASSWORD resets the owner and admin passwords
# to the values below (use only for a known good recovery, then turn off).
NEXA_SEED_ON_BOOT=
NEXA_OWNER_EMAIL=
NEXA_OWNER_PASSWORD=
NEXA_ADMIN_EMAIL=
NEXA_ADMIN_PASSWORD=
NEXA_SEED_FORCE_PASSWORD=

# Provider keys, read only by the Brain. Leave blank when keys are connected through the secret
# store (resolved store first by the model router).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
TAVILY_API_KEY=
