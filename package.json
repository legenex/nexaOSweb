{
  "name": "nexaosweb",
  "private": true,
  "version": "0.0.0",
  "description": "nexaOSweb, a personal AI operating system. One web frontend, three targets.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "build:web": "pnpm --filter web build",
    "lint": "eslint .",
    "lint:ws": "pnpm -r --if-present lint",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "gen:client": "pnpm --filter @nexaosweb/api-client --if-present generate"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "eslint": "^9.13.0",
    "globals": "^15.11.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.11.0"
  }
}
