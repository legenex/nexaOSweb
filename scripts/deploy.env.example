# Deploy secret values for nexaOSweb. Copy this file to scripts/deploy.env and fill it in.
# scripts/deploy.env is gitignored, never commit real values.
# Then run: bash scripts/set-deploy-secrets.sh
#
# All six PLESK_* values are required. The two VITE_DOWNLOAD_* are optional
# (homepage installer links), leave them blank to skip.

# SSH host, the Plesk server hostname or IP.
PLESK_HOST=

# SSH system user with access to the subscription. In Plesk this is set under
# Websites & Domains, Web Hosting Access (or a dedicated system user you created).
PLESK_USER=

# Path to the PRIVATE SSH key that authenticates PLESK_USER on the server. Keep it
# OUTSIDE the repo, for example ~/.ssh/nexaos_deploy. The script reads this file and
# stores its contents as the PLESK_SSH_KEY secret. Do not paste the key inline.
PLESK_SSH_KEY_FILE=~/.ssh/nexaos_deploy

# Document root the built web is shipped to (served by Nginx at the site root).
# Example: /var/www/vhosts/yourdomain.com/httpdocs
PLESK_WEB_ROOT=

# Directory the Brain source is shipped to and the Docker image is built in.
# Example: /var/www/vhosts/yourdomain.com/brain
PLESK_BRAIN_DIR=

# Public health URL used to verify the deploy. Must return {"status":"ok"}.
# Example: https://yourdomain.com/api/healthz
PLESK_HEALTH_URL=

# Optional: direct download URLs for the published desktop installers.
VITE_DOWNLOAD_MACOS=
VITE_DOWNLOAD_WINDOWS=
